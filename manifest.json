{
    "name": "Blank new tab",
    "version": "1.0",
    "description": "Replaces the default new tab with a clean blank page.",
    "manifest_version": 3,
    "permissions":["storage"],
    "chrome_url_overrides": {
      "newtab": "blank.html"
    },
    "action":{
        "default_popup":"options.html",
        "default_icon":"icon.png"
    }
  }