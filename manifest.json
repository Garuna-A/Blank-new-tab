{
    "name": "Blank new tab",
    "version": "1.0",
    "description": "Replaces the default new tab with a clean blank page.",
    "manifest_version": 3,
    "permissions":["storage"],
    "chrome_url_overrides": {
      "newtab": "blank.html"
    },
    "options_ui":{
        "page":"options.html",
        "open_in_tab":true
    }
  }